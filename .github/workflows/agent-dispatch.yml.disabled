name: Agent Dispatch on PR

on:
  pull_request:
    types: [opened, synchronize, reopened]

concurrency:
  group: agent-dispatch-${{ github.ref }}
  cancel-in-progress: true

jobs:
  dispatch:
    name: Route changed files to agents
    runs-on: ubuntu-latest
    permissions:
      pull-requests: write
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Compute changed files
        id: changed
        run: |
          git diff --name-only \
            ${{ github.event.pull_request.base.sha }} \
            ${{ github.sha }} \
            | tee /tmp/changed-files.txt
          COUNT=$(grep -c . /tmp/changed-files.txt || echo 0)
          echo "count=$COUNT" >> "$GITHUB_OUTPUT"

      - name: Run agent dispatch
        if: steps.changed.outputs.count != '0'
        run: |
          node agent-architecture/scripts/dispatch-on-change.mjs \
            --files /tmp/changed-files.txt \
            --output /tmp/dispatch-plan.json
          echo "=== Dispatch Plan ==="
          cat /tmp/dispatch-plan.json

      - name: Post dispatch plan as PR comment
        if: steps.changed.outputs.count != '0'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const plan = JSON.parse(fs.readFileSync('/tmp/dispatch-plan.json', 'utf8'));

            const lines = [
              '## Agent Dispatch Plan',
              '',
              `**${plan.totalFiles} file(s) changed** across **${plan.agents.length} agent scope(s)**`,
              '',
              '> Invoke the agents below on the listed files. Disjoint scopes can run in parallel.',
              '',
            ];

            for (const agent of plan.agents) {
              lines.push(`### \`${agent.invoke}\``);
              lines.push('');
              lines.push(`**Why:** ${agent.reasons.join(', ')}`);
              lines.push('');
              const shown = agent.files.slice(0, 15);
              const rest = agent.files.length - shown.length;
              lines.push('**Files:**');
              for (const f of shown) lines.push(`- \`${f}\``);
              if (rest > 0) lines.push(`- _…and ${rest} more_`);
              lines.push('');
            }

            lines.push('---');
            lines.push('_Generated by [`dispatch-on-change.mjs`](agent-architecture/scripts/dispatch-on-change.mjs) via [agent-architecture](agent-architecture/)_');

            const body = lines.join('\n');

            // Update existing bot comment if present, otherwise create
            const { data: comments } = await github.rest.issues.listComments({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.payload.pull_request.number,
            });

            const existing = comments.find(
              (c) => c.user.type === 'Bot' && c.body.startsWith('## Agent Dispatch Plan')
            );

            if (existing) {
              await github.rest.issues.updateComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                comment_id: existing.id,
                body,
              });
            } else {
              await github.rest.issues.createComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: context.payload.pull_request.number,
                body,
              });
            }
