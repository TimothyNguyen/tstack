{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "node \"${ARCHITECTURE_AGENT_ROOT}/adapters/ponytail/hooks/ponytail-activate.cjs\"",
        "powershell": "node \"${ARCHITECTURE_AGENT_ROOT}\\adapters\\ponytail\\hooks\\ponytail-activate.cjs\"",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node \"${ARCHITECTURE_AGENT_ROOT}/adapters/ponytail/hooks/ponytail-mode-tracker.cjs\"",
        "powershell": "node \"${ARCHITECTURE_AGENT_ROOT}\\adapters\\ponytail\\hooks\\ponytail-mode-tracker.cjs\"",
        "timeoutSec": 5
      }
    ]
  }
}
