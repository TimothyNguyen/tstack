# Dummy mcp-atlassian profile for atlassian-docs.
# Replace placeholders locally through approved secret management.
# Do not put real tokens in this file.

READ_ONLY_MODE=true
ATLASSIAN_OAUTH_PROXY_ENABLE=false
JIRA_SSL_VERIFY=true
CONFLUENCE_SSL_VERIFY=true

MCP_ALLOWED_URL_DOMAINS=example.atlassian.net
TOOLSETS=default
ENABLED_TOOLS=confluence_search,confluence_get_page,jira_search,jira_get_issue

CONFLUENCE_URL=https://example.atlassian.net/wiki
CONFLUENCE_USERNAME=user@example.com
CONFLUENCE_API_TOKEN=dummy-confluence-api-token

JIRA_URL=https://example.atlassian.net
JIRA_USERNAME=user@example.com
JIRA_API_TOKEN=dummy-jira-api-token
