{
  "name": "agent-pack",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "workspaces": [
    "adapters"
  ],
  "description": "Enterprise-safe TStack agent definitions for agent-registry and agent-harness.",
  "bin": {
    "agent-pack": "./bin/agent-pack.mjs",
    "agent-architecture": "./bin/agent-architecture.mjs"
  },
  "files": [
    ".agent-config.example.json",
    "bin/",
    "scripts/install.mjs",
    "agents/",
    "adapters/",
    "core/",
    "domains/",
    "hooks/",
    "hosts/",
    "plugins/",
    "policies/",
    "profiles/",
    "docs/",
    "generated/",
    "references/",
    "skills/",
    "stacks/",
    "tool-providers/"
  ],
  "scripts": {
    "scaffold:skills": "node scripts/scaffold-skills.mjs",
    "build:skills": "node scripts/gen-skill-docs.mjs && npm run build:index && npm run build:registry && npm run gen:catalog && npm run gen:training-data",
    "check:skills": "node scripts/gen-skill-docs.mjs --check && npm run check:index && npm run check:registry && npm run check:catalog && npm run check:training-data",
    "gen:hosts": "node scripts/gen-host-artifacts.mjs",
    "check:hosts": "node scripts/gen-host-artifacts.mjs --check",
    "gen:catalog": "node scripts/gen-catalog.mjs",
    "check:catalog": "node scripts/gen-catalog.mjs --check",
    "gen:training-data": "node scripts/gen-training-data.mjs",
    "check:training-data": "node scripts/gen-training-data.mjs --check",
    "validate:metadata": "node scripts/validate-metadata.mjs \"*\"",
    "subagents:deploy": "node scripts/subagent-deploy.mjs",
    "subagents:import": "node scripts/subagent-import.mjs",
    "install:pack": "npm pack",
    "doctor": "node scripts/install.mjs --doctor",
    "vet:vendored": "node scripts/vet-vendored.mjs",
    "build:index": "node scripts/gen-skill-index.mjs",
    "check:index": "node scripts/gen-skill-index.mjs --check",
    "build:registry": "node scripts/build-skills-registry.mjs",
    "check:registry": "node scripts/build-skills-registry.mjs --check",
    "sync:agents": "node scripts/sync-agent-skills.mjs && npm run build:skills",
    "check:agents": "node scripts/sync-agent-skills.mjs --check",
    "test": "node --test tests/*.test.mjs",
    "test:integration": "node --test tests/integration/*.test.mjs",
    "test:all": "node --test tests/*.test.mjs && node --test tests/integration/*.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:free:list": "node scripts/test-free-shards.mjs --list",
    "test:free:windows": "node scripts/test-free-shards.mjs --windows-only --list"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0"
  }
}
