# Safe mcp-atlassian profile for agent-pack atlassian-docs.
# Fill URLs and secrets through approved secret management; do not commit real tokens.

READ_ONLY_MODE=true
ATLASSIAN_OAUTH_PROXY_ENABLE=false
JIRA_SSL_VERIFY=true
CONFLUENCE_SSL_VERIFY=true

# Restrict to approved Atlassian Cloud or Data Center hosts.
MCP_ALLOWED_URL_DOMAINS=atlassian.net

# Keep toolsets explicit because unset TOOLSETS currently enables all mcp-atlassian toolsets.
TOOLSETS=default

# Keep the active tool list narrower than the default toolset.
ENABLED_TOOLS=confluence_search,confluence_get_page,jira_search,jira_get_issue

# Examples only. Use approved secret injection for usernames and tokens.
# CONFLUENCE_URL=https://example.atlassian.net/wiki
# JIRA_URL=https://example.atlassian.net
# CONFLUENCE_USERNAME=
# CONFLUENCE_API_TOKEN=
# JIRA_USERNAME=
# JIRA_API_TOKEN=
