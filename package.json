{
  "name": "tstack-governance",
  "version": "1.1.0",
  "description": "Governance Engine for repository standards enforcement",
  "scripts": {
    "governance:build": "node scripts/build-governance.js",
    "governance:check": "node bin/governance.js check",
    "governance:check:hard": "node bin/governance.js check:hard",
    "governance:check:soft": "node bin/governance.js check:soft",
    "governance:fix": "node scripts/build-governance.js",
    "governance:health": "node bin/governance.js health",
    "governance:validate": "node bin/governance.js validate",
    "governance:report": "node bin/governance.js report",
    "test": "node --test --test-concurrency=1 tests/*.test.js",
    "coverage": "node --test --test-concurrency=1 --experimental-test-coverage --test-coverage-include=bin/*.js --test-coverage-include=scripts/*.js --test-coverage-lines=95 --test-coverage-functions=95 tests/*.test.js"
  },
  "devDependencies": {
    "js-yaml": "^4.1.0"
  }
}
